#!/usr/bin/env bash

if [[ $# -lt 2 ]]; then
    echo "Usage: $0 <filename> <email1> [email2 ...]"
    exit 1
fi

FILENAME=$1
shift

eval "$(ssh-agent -s)"

for EMAIL in "$@"; do
    TARGET_KEY="$HOME/.ssh/${FILENAME}_${EMAIL//[^a-zA-Z0-9]/_}"

    ssh-keygen -t ed25519 -C "$EMAIL" -f "$TARGET_KEY" -N ""
    ssh-add "$TARGET_KEY"
    cat "${TARGET_KEY}.pub"
    echo "----------------------------------------"
done
